API_PORT=8787
VITE_API_BASE=http://127.0.0.1:8787/api
CORS_ORIGIN=http://127.0.0.1:5173

# Database
# Use "postgres" for beta/production. JSON is only a local fallback.
DB_CLIENT=postgres
DATABASE_URL=postgres://baytak_user:baytak_password_change_me@127.0.0.1:55432/baytak
DB_POOL_MAX=20
DB_SSL=false

# Local auth/session hardening
SESSION_TTL_MS=604800000
PASSWORD_ITERATIONS=120000
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=12
OTP_SECRET=replace-with-a-long-random-secret-before-beta
SETUP_ADMIN_KEY=replace-with-a-long-random-admin-setup-key

# OTP delivery is paused until the official provider is connected.
# Use "whatsapp_cloud" or "sms_webhook" when credentials are ready.
# Use "mock" only for controlled local testing.
OTP_DELIVERY_MODE=paused
OTP_TTL_MS=300000
OTP_RESEND_COOLDOWN_MS=60000
OTP_MAX_ATTEMPTS=5

# WhatsApp Cloud OTP adapter
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_AUTH_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# SMS webhook OTP adapter
SMS_WEBHOOK_URL=

# Payment gateway adapter.
# Keep "held" until the bank provides the endpoint and merchant credentials.
PAYMENT_GATEWAY_MODE=held
PAYMENT_WEBHOOK_URL=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_MERCHANT_ID=

# Dangerous local-only maintenance.
ALLOW_RESET=false
